{
  "expo": {
    "name": "stemm-lab",
    "slug": "stemm-lab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "STEMM Lab needs the microphone to measure sound levels for the Sound Pollution Hunter activity.",
        "NSCameraUsageDescription": "STEMM Lab uses the camera to record photos of your fan designs for the Hand Fan Challenge."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "STEMM Lab uses the camera to record photos of your fan designs."
        }
      ],
      "expo-video"
    ]
  }
}
